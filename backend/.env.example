# Server
PORT=5000
NODE_ENV=production

# Comma-separated list of frontend URLs allowed to call this API.
# Local dev:        http://localhost:5173
# After deploying:  https://your-frontend.vercel.app
# You can list both at once, separated by commas, with no spaces needed:
# CLIENT_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# ---- MongoDB Atlas ------------------------------------------------------
# 1. Create a free cluster at https://cloud.mongodb.com
# 2. Database Access -> Add New Database User (username + password, "Read and write to any database")
# 3. Network Access -> Add IP Address -> 0.0.0.0/0 (allow access from anywhere, needed for most hosting providers)
# 4. Database -> Connect -> Drivers -> copy the connection string and replace <username>/<password> below.
# 5. Add a database name after ".net/" — Atlas creates it automatically on first write, you don't
#    need to create it manually. This project uses "speech-assistant" as the example name.
#
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/speech-assistant?retryWrites=true&w=majority
MONGO_URI=ypur_MONGO_URI
# ---- Google Gemini -------------------------------------------------------
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini model to call. gemini-2.5-flash is fast + cheap and good for a voice
# assistant. Swap for any model your API key has access to.
GEMINI_MODEL=gemini-2.5-flash
